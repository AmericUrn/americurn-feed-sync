# Copy to .env and fill in real values. .env is gitignored.

# Shopify - subdomain only (the part before .myshopify.com)
SHOPIFY_STORE=americurn

# Client ID + secret from the custom app in Shopify Partner Dashboard.
# Only used during the one-time `npm run get-token` setup.
SHOPIFY_CLIENT_ID=your_client_id_here
SHOPIFY_CLIENT_SECRET=your_client_secret_here

# Admin API access token obtained from `npm run get-token`.
# This is what sync.mjs actually uses for every run.
SHOPIFY_ACCESS_TOKEN=will_be_filled_after_running_get_token

# Google
GOOGLE_SHEET_ID=1y3Gnr4ug1Kc7GAUY7u9iT-U0mDfx8yOd16hD4BBBVW4
GOOGLE_SERVICE_ACCOUNT_KEY=./service-account.json
